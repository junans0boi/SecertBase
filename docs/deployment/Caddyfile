secertbase.kro.kr {
	root * /var/www/secretbase
	encode zstd gzip

	@backend path /api/* /uploads/* /health /socket.io/*
	handle @backend {
		reverse_proxy 127.0.0.1:4100
	}

	handle {
		try_files {path} /index.html
		# Flutter 웹 빌드는 파일명이 고정(MaterialIcons 폰트 등)이라
		# 재검증 없이 캐시하면 배포 후에도 옛 파일을 씀 → etag 304 재검증 강제
		header Cache-Control "no-cache"
		file_server
	}
}

test.secertbase.kro.kr {
	root * /var/www/secretbase-test
	encode zstd gzip

	@backend path /api/* /uploads/* /health /socket.io/*
	handle @backend {
		reverse_proxy 127.0.0.1:4100
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
